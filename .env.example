APP_NAME=office-agent
APP_ENV=local
# Server deployment: bind HTTP service to all interfaces so remote clients can reach it
HOST=0.0.0.0
PORT=8000
PUBLIC_BASE_URL=

# MCP Server
# stdio: for same-host MCP clients such as AstrBot MCP config
# streamable-http: for server deployment and remote MCP clients
MCP_TRANSPORT=streamable-http
# Bind MCP service to all interfaces for remote tool access
MCP_HOST=0.0.0.0
MCP_PORT=8010
MCP_STREAMABLE_HTTP_PATH=/mcp
MCP_SSE_PATH=/sse
MCP_MESSAGE_PATH=/messages/
MCP_STATELESS_HTTP=false

# Agent Brain Mode
# true: Enable autonomous agent with planning, memory, and AI tool reasoning
# false: Pure MCP tools mode, let external AI tools (like AstrBot) orchestrate tools
ENABLE_AGENT_BRAIN=false

# DeepSeek API Configuration (required when ENABLE_AGENT_BRAIN=true)
# Get your API key from https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 备选 AI 工具配置（如 DeepSeek 或比赛允许的 AI 工具）
# AI_TOOL_API_KEY=your-api-key
# AI_TOOL_BASE_URL=https://api.example.com/v1
# AI_TOOL_MODEL=your-model

# DingTalk Open Platform API
# Apply at https://open.dingtalk.com/ > Application Development > Enterprise Internal Development
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
# DINGTALK_API_BASE_URL=https://api.dingtalk.com

# SQLite path can be absolute or relative to project root.
DATABASE_PATH=data/office_agent.db

# File storage and PDF conversion
UPLOAD_DIR=data/files
# Local process: use http://127.0.0.1:3000
# Docker container calling same-server Gotenberg port: use http://host.docker.internal:3000
# Same docker compose network: use http://gotenberg:3000
GOTENBERG_URL=http://host.docker.internal:3000
GOTENBERG_TIMEOUT=120
# Mounted by docker-compose from ../gotenberg/fonts.
OFFICE_AGENT_FONT_DIR=/usr/local/share/fonts/office-agent
OFFICE_AGENT_DOCX_FONT=Noto Serif CJK SC

# SMTP Email Configuration
# For Gmail: smtp.gmail.com, port 587, use STARTTLS (enable SMTP_USE_STARTTLS, disable SMTP_USE_TLS)
# For QQ Mail: smtp.qq.com, port 465, use implicit TLS (enable SMTP_USE_TLS, disable SMTP_USE_STARTTLS)
# For general SMTP: adjust host and port accordingly
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TIMEOUT=30
SMTP_USE_TLS=true
SMTP_USE_STARTTLS=false

# Cross-platform notice robot webhooks.
# Use one-line JSON. Supported platform values: dingtalk, wecom, feishu.
# DingTalk can include "secret" when robot signature is enabled.
NOTICE_CHANNELS={"dingding_dev_group":{"platform":"dingtalk","name":"钉钉研发群","webhook_url":"https://oapi.dingtalk.com/robot/send?access_token=xxx","secret":""},"wechat_project_group":{"platform":"wecom","name":"企业微信项目群","webhook_url":"https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx"},"feishu_office_group":{"platform":"feishu","name":"飞书办公群","webhook_url":"https://open.feishu.cn/open-apis/bot/v2/hook/xxx"}}
